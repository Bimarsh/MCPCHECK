# Optional but recommended to avoid low GitHub anonymous API rate limits.
GITHUB_TOKEN=

# Production: use the Neon Postgres pooled connection string.
# Example:
# DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Local/test fallback when DATABASE_URL is empty.
MCPCHECK_SQLITE_PATH=/tmp/mcpcheck.db

# Static analysis limits. Keep these conservative for Vercel functions.
MCP_MAX_FILES=80
MCP_MAX_FILE_BYTES=120000
MCP_MAX_TREE_ITEMS=2500

